# ========================================
# CMV Backend Environment Configuration
# ========================================

# ========== GENERAL SETTINGS ==========
NODE_ENV=development
PORT=5002

# ========== DATABASE ==========
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/cmv_db?retryWrites=true&w=majority

# ========== ENCRYPTION SETTINGS ==========
# PAN Encryption is CRITICAL for security
# Generate a 32-byte key: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PAN_ENCRYPTION_ENABLED=true
ENCRYPTION_KEY=your-base64-encoded-32-byte-key-here

# ========== EMAIL CONFIGURATION ==========
# Primary: GoDaddy SMTP
EMAIL_HOST=smtp.godaddy.com
EMAIL_PORT=465
EMAIL_USER=noreply@chinmayamissionvasai.com
EMAIL_PASSWORD=your-godaddy-password

# Fallback: Gmail SMTP (if GoDaddy fails)
GMAIL_USER=your-gmail@gmail.com
GMAIL_PASSWORD=your-app-specific-password

# Optional: SendGrid
SENDGRID_API_KEY=your-sendgrid-key

# ========== MSWIPE PAYMENT GATEWAY ==========
# For Testing (UAT)
MSWIPE_ENV=uat
MSWIPE_USER_ID=your_uat_user_id
MSWIPE_CLIENT_ID=your_uat_client_id
MSWIPE_PASSWORD=your_uat_password
MSWIPE_CUST_CODE=your_uat_cust_code

# For Production (uncomment when ready)
# MSWIPE_ENV=production
# MSWIPE_USER_ID=your_production_user_id
# MSWIPE_CLIENT_ID=your_production_client_id
# MSWIPE_PASSWORD=your_production_password
# MSWIPE_CUST_CODE=your_production_cust_code

# Fixed Mswipe API Parameters
MSWIPE_APPL_ID=api
MSWIPE_CHANNEL_ID=pbl
MSWIPE_VERSION=VER4.0.0

# Redirect URLs after payment
MSWIPE_REDIRECT_URL=http://localhost:3000/payment-result
FRONTEND_PAYMENT_RESULT_URL=http://localhost:3000/donation/result

# ========== CORS CONFIGURATION ==========
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ========== LOGGER CONFIGURATION ==========
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# ========== RECEIPT CONFIGURATION ==========
RECEIPT_ORG_NAME=Chinmaya Mission Vasai
RECEIPT_ORG_ADDRESS=Karmavir Bhaurao Patil Path, Vasai West, Mumbai
RECEIPT_ORG_CITY=Vasai
RECEIPT_ORG_STATE=Maharashtra
RECEIPT_ORG_PINCODE=401201
RECEIPT_ORG_EMAIL=donations@chinmayamissionvasai.com
RECEIPT_ORG_WEBSITE=www.chinmayamissionvasai.com

# ========== TWO-FACTOR AUTHENTICATION ==========
# OTP Provider: 'sms' for SMS-based, 'email' for email-based
TWO_FACTOR_METHOD=sms
OTP_VALIDITY_SECONDS=300
OTP_MAX_ATTEMPTS=3

# ========== SMS PROVIDER (Twilio Example) ==========
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ========== JWT CONFIGURATION (if using auth) ==========
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRY=24h

# ========== SESSION CONFIGURATION ==========
SESSION_SECRET=your-session-secret-key
SESSION_EXPIRE_DAYS=7

# ========== RATE LIMITING ==========
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========== MONITORING & DEBUG ==========
DEBUG=cmv:*
SENTRY_DSN=your-sentry-dsn-for-error-tracking

# ========== AWS S3 (for file uploads) ==========
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=cmv-uploads

# ========== CLOUDINARY (for image uploads) ==========
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ========== ANALYTICS & TRACKING ==========
GOOGLE_ANALYTICS_ID=your-ga-id
MIXPANEL_TOKEN=your-mixpanel-token
